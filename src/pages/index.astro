---
import BaseLayout from '../layouts/BaseLayout.astro';

// First-draft copy — easy to swap out once real marketing copy/lore is
// ready to pull in from the existing lore/rules material.
const tagline = 'Command a Nexus Lord. Master the Leylines. Claim the affinity war.';
const pitch =
  "Leylines of Power is a trading card game of elemental affinities and legendary avatars. " +
  'Choose a Nexus Lord, channel the power of the Leylines, and out-maneuver your rival across ' +
  'creatures, chants, and relics drawn from six warring affinities. The game is in active ' +
  'playtesting — jump into the sandbox simulator to try it yourself.';
---

<BaseLayout title="Leylines of Power">
  <section class="hero">
    <img class="hero-logo" src="/icons/lop-logo.png" alt="Leylines of Power" />
    <h1>{tagline}</h1>
    <p class="pitch">{pitch}</p>
    <a class="cta" href="https://play.leylinesofpower.com">Play Now — Free Sandbox Simulator</a>
    <p class="cta-note">Runs right in your browser. No download, no install.</p>
  </section>
</BaseLayout>

<style>
  .hero {
    max-width: 720px;
    margin: 0 auto;
    padding: 12vh 24px 10vh;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }
  .hero-logo {
    width: 120px;
    height: 120px;
    object-fit: contain;
    margin-bottom: 8px;
  }
  h1 {
    margin: 0;
    font-size: clamp(28px, 4vw, 42px);
    line-height: 1.25;
    color: var(--gold-bright);
  }
  .pitch {
    margin: 0;
    color: var(--fg);
    opacity: 0.85;
    font-size: 16px;
    line-height: 1.6;
  }
  .cta {
    margin-top: 12px;
    background: linear-gradient(165deg, var(--gold-bright), var(--gold));
    color: #241f1a;
    font-weight: 700;
    text-decoration: none;
    padding: 16px 32px;
    border-radius: 10px;
    font-size: 17px;
    letter-spacing: 0.2px;
    box-shadow: 0 8px 24px rgba(205, 169, 79, 0.3);
  }
  .cta-note {
    margin: 0;
    color: var(--muted-fg);
    font-size: 13px;
  }
</style>
