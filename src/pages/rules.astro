---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Rules — Leylines of Power" description="The rules of Leylines of Power — coming soon.">
  <div class="content-bg">
    <section class="placeholder-wrap">
      <div class="framed-panel">
        <div class="gold-corners">
          <span class="gold-corner gold-corner-tl"></span>
          <span class="gold-corner gold-corner-tr"></span>
          <span class="gold-corner gold-corner-bl"></span>
          <span class="gold-corner gold-corner-br"></span>
        </div>
        <p class="eyebrow">Rules</p>
        <h1>The rulebook is being rewritten.</h1>
        <p>
          Leylines of Power is still in active playtesting, and the rules text is being revised to match.
          A full, readable rules page is coming here soon — in the meantime, the simulator enforces nothing,
          so playtesters are already using the latest draft directly.
        </p>
        <a class="cta btn-gold" href="/">Back to Home</a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* Same ambient background + bordered-panel treatment as the homepage's
     Tools/Final-CTA sections — see src/pages/index.astro for the fuller
     version of these comments. --gold/--gold-bright are the darker
     antique-gold tone globally now (see global.css), no override needed. */
  .content-bg {
    position: relative;
    min-height: 100%;
  }
  .content-bg::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    aspect-ratio: 1659 / 948;
    z-index: 0;
    pointer-events: none;
    opacity: 0.35;
    background-image: url('/ornaments/setup-bg.png');
    background-size: 100% 100%;
    background-position: center top;
    background-repeat: no-repeat;
    -webkit-mask-image: linear-gradient(to bottom, black 0%, black 68%, transparent 100%);
    mask-image: linear-gradient(to bottom, black 0%, black 68%, transparent 100%);
  }
  .placeholder-wrap {
    position: relative;
    z-index: 1;
    padding: 12vh 24px;
  }
  .framed-panel {
    position: relative;
    max-width: 640px;
    margin: 0 auto;
    padding: 56px 48px;
    background: linear-gradient(165deg, var(--sidebar-bg-2), var(--sidebar-bg));
    border-radius: 12px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }
  .framed-panel::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    border-style: solid;
    border-width: 8px;
    border-image-source: url('/ornaments/box-frame-2.png');
    border-image-slice: 16;
    border-image-width: 8px;
    border-image-repeat: stretch;
    border-radius: 12px;
    filter: brightness(1.05) saturate(1.15) hue-rotate(-4deg);
  }
  /* Small gold "jeweled corner" accents — same treatment as the simulator's
     Deck Builder/Board zone corners and the homepage's framed panels (see
     src/pages/index.astro for the fuller comment), replacing the old ornate
     corner-bracket image flourish. */
  .gold-corners {
    position: absolute;
    inset: 10px;
    pointer-events: none;
    z-index: 10;
  }
  .gold-corner {
    position: absolute;
    width: 26px;
    height: 26px;
    border: 0 solid var(--gold-bright);
    opacity: 0.9;
    filter: drop-shadow(0 0 2px rgba(205, 169, 79, 0.4));
  }
  .gold-corner::before {
    content: '';
    position: absolute;
    width: 6px;
    height: 6px;
    background: var(--gold-bright);
    transform: rotate(45deg);
    opacity: 0.95;
    box-shadow: 0 0 3px rgba(232, 201, 119, 0.55);
  }
  .gold-corner-tl {
    top: 0;
    left: 0;
    border-top-width: 2px;
    border-left-width: 2px;
    border-top-left-radius: 6px;
  }
  .gold-corner-tl::before {
    top: -3px;
    left: -3px;
  }
  .gold-corner-tr {
    top: 0;
    right: 0;
    border-top-width: 2px;
    border-right-width: 2px;
    border-top-right-radius: 6px;
  }
  .gold-corner-tr::before {
    top: -3px;
    right: -3px;
  }
  .gold-corner-bl {
    bottom: 0;
    left: 0;
    border-bottom-width: 2px;
    border-left-width: 2px;
    border-bottom-left-radius: 6px;
  }
  .gold-corner-bl::before {
    bottom: -3px;
    left: -3px;
  }
  .gold-corner-br {
    bottom: 0;
    right: 0;
    border-bottom-width: 2px;
    border-right-width: 2px;
    border-bottom-right-radius: 6px;
  }
  .gold-corner-br::before {
    bottom: -3px;
    right: -3px;
  }
  h1 {
    margin: 6px 0 0;
    font-size: clamp(24px, 3.2vw, 34px);
    color: var(--gold-bright);
  }
  p {
    margin: 0;
    color: var(--fg);
    opacity: 0.85;
    font-size: 16px;
    line-height: 1.6;
  }
  .cta {
    margin-top: 12px;
    padding: 14px 28px;
    font-size: 15px;
  }
</style>
